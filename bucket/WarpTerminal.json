{
    "version": "0.2026.07.22.09.01.stable_01",
    "description": "Modern, Rust-based terminal with AI built in so you and your team can build great software, faster.",
    "homepage": "https://www.warp.dev/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://www.warp.dev/terms-of-service"
    },
    "depends": "Scoop4kariiin/Scoop4kariiinUtils",
    "architecture": {
        "64bit": {
            "url": "https://releases.warp.dev/stable/v0.2026.07.22.09.01.stable_01/WarpSetup.exe",
            "hash": "d0c8a63d5872f05c835d280080cb6b5ecb84f789399cdd39893d3428037d5d0f"
        },
        "arm64": {
            "url": "https://releases.warp.dev/stable/v0.2026.07.22.09.01.stable_01/WarpSetup-arm64.exe",
            "hash": "cd95f794223a7b7502d3833b9a5c05070ffa1cd93553c73e1068554c77001f88"
        }
    },
    "innosetup": true,
    "installer": {
        "script": [
            "Import-Module -Name Scoop4kariiinUtils -ErrorAction Stop",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\warp\" -LocalAppData",
            "Remove-Module -Name Scoop4kariiinUtils -ErrorAction SilentlyContinue"
        ]
    },
    "shortcuts": [
        [
            "warp.exe",
            "Warp"
        ]
    ],
    "uninstaller": {
        "script": [
            "Import-Module -Name Scoop4kariiinUtils -ErrorAction Stop",
            "Dismount-ExternalRuntimeData -Target \"warp\" -LocalAppData",
            "Remove-Module -Name Scoop4kariiinUtils -ErrorAction SilentlyContinue"
        ]
    },
    "checkver": {
        "script": "[System.Net.HttpWebRequest]::Create('https://app.warp.dev/download?package=exe_x86_64').GetResponse().ResponseUri.AbsoluteUri",
        "regex": "/v([\\d.]+stable_\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://releases.warp.dev/stable/v$version/WarpSetup.exe"
            },
            "arm64": {
                "url": "https://releases.warp.dev/stable/v$version/WarpSetup-arm64.exe"
            }
        }
    }
}
